# Copy this file to .env and fill in your own credentials.
# Never publish or commit .env.

# Volcengine Ark / Doubao
ARK_API_KEY=
ARK_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_REASONING_EFFORT=minimal

# Volcengine TOS, required when uploading local video files for Ark access
TOS_ACCESS_KEY_ID=
TOS_ACCESS_KEY_SECRET=
TOS_BUCKET=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_KEY_PREFIX=doubao-multimodal

# WeChat Official Account
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_AUTHOR=
